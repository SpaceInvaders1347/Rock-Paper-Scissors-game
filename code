import tkinter as tk
import random as rd

# 1. Function to handle the game logic
def play(user_choice):
    choice_pool = ["rock", "paper", "scissors"]
    comp_pick = rd.choice(choice_pool)
    
    if user_choice == comp_pick:
        result = "It's a Tie! 🤝"
    elif (user_choice == "rock" and comp_pick == "scissors") or \
         (user_choice == "paper" and comp_pick == "rock") or \
         (user_choice == "scissors" and comp_pick == "paper"):
        result = "You Win! 🎉"
    else:
        result = "Computer Wins! 💻"
        
    result_label.config(text=result)
    details_label.config(text=f"You chose {user_choice.title()}\nComputer chose {comp_pick.title()}")

# Setup main window
window = tk.Tk()
window.title("Rock Paper Scissors Game")
window.geometry("300x320")

# Set the background color of the main window
window.configure(bg="skyblue") 

# 2. Add labels (matching the skyblue background)
result_label = tk.Label(
    window, 
    text="Make your choice!", 
    font=("Helvetica", 14, "bold"),
    bg="skyblue",        # Matches window background
    fg="#1C3144"         # Dark slate text for good contrast
)
result_label.pack(pady=15)

details_label = tk.Label(
    window, 
    text="", 
    bg="skyblue",        # Matches window background
    fg="#1C3144",
    font=("Helvetica", 10)
)
details_label.pack(pady=10)

# 3. Game buttons
btn_rock = tk.Button(
    text="Rock",
    bg="white",
    fg="black",
    width=20,
    command=lambda: play("rock")
)
btn_rock.pack(pady=5)

btn_paper = tk.Button(
    text="Paper",
    bg="white",
    fg="black",
    width=20,
    command=lambda: play("paper")
)
btn_paper.pack(pady=5)

btn_scissors = tk.Button(
    text="Scissors",
    bg="white",
    fg="black",
    width=20,
    command=lambda: play("scissors")
)
btn_scissors.pack(pady=5)

window.mainloop()
